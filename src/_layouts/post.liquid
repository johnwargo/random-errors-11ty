---
layout: default
---

{% assign previousPost = collections.post | getPreviousCollectionItem %}
{% assign nextPost = collections.post | getNextCollectionItem %}
{% include 'pretty-print.html' %}

<header>
  <h2>{{ title }}</h2>
</header>
<p>
  <strong>Posted:
  </strong>
  {{ date | readableDate }} |
  <strong>Categories:</strong>
  {% for cat in categories %}
    <a href="/categories/{{ cat | slugify }}">{{ cat }}</a>
    {% unless forloop.last %},&nbsp;
    {% endunless %}
  {% endfor %}
</p>

{{ content }}

<hr />
{% if nextPost %}
<p>Next Post:
  <a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a>
</p>
{% endif %}
{% if previousPost %}
<p>Previous Post:
  <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a>
</p>
{% endif %}

<div class="coffee">
  <script
    type="text/javascript"
    src="https://cdnjs.buymeacoffee.com/1.0.0/button.prod.min.js"
    data-name="bmc-button"
    data-slug="johnwargo"
    data-color="#FFDD00"
    data-emoji=""
    data-font="Inter"
    data-text="Buy me a coffee"
    data-outline-color="#000000"
    data-font-color="#000000"
    data-coffee-color="#ffffff"></script>
  <p>If this post helps you in some way, please consider buying me a coffee.</p>
</div>